# ============================================================================
# Müşteri Hizmetleri AI — Ortam Değişkenleri
# ============================================================================
# Bu dosyayı `.env` olarak kopyalayın, kendi anahtarlarınızı yazın.

# --- Sunucu ---
PORT=3500

# --- İşletme Bilgileri ---
BUSINESS_NAME=Peçen Toptan
BUSINESS_SECTOR=Toptan Satış
BUSINESS_IBAN=
BUSINESS_PHONE=

# --- Meta (Instagram + Messenger) ---
# Meta for Developers → Uygulama → Ayarlar → Temel
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=musteri_hizmetleri_verify_2026
META_APP_SECRET=

# --- Gemini AI ---
# Google AI Studio → API Keys → https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Google Sheets (Ürün Kataloğu) ---
# Sheets'i "Bağlantısı olan herkes görüntüleyebilir" olarak paylaşın
# URL'deki /d/ ile /edit arasındaki ID'yi kopyalayın
GOOGLE_SHEETS_ID=

# --- Eskalasyon ---
ESCALATION_EMAIL=
ADMIN_NOTIFY_EMAIL=

# --- WhatsApp ---
# ManyChat üzerinden bağlantı (varsayılan): /webhook/manychat?platform=whatsapp
# AutoResponder ile bağlantı (alternatif): templates/autoresponder_template.js'e bakın
# Güvenlik şifresi (opsiyonel, sadece AutoResponder için geçerli)
WHATSAPP_WEBHOOK_SECRET=
